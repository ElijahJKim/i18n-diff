{
  "manifest_version": 3,
  "name": "i18n Diff",
  "description": "A real-time layout guard that detects UI text overflow by applying multilingual JSON data to webpages",
  "version": "1.0.0",
  "private": true,
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "small-logo.png",
      "48": "small-logo.png",
      "128": "big-logo.jpeg"
    }
  },
  "icons": {
    "16": "small-logo.png",
    "48": "small-logo.png",
    "128": "big-logo.jpeg"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-DsKPga3f.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/index.ts-DsKPga3f.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
